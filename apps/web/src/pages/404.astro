---
import PageLayout from "../layouts/PageLayout.astro"
import { Button } from "@leaner/ui/components/button"
---

<PageLayout title="Not found" description="This page could not be found." path="/404">
  <section class="mx-auto flex max-w-2xl flex-col items-center px-6 py-32 text-center">
    <p class="from-brand-teal to-brand-pink bg-gradient-to-r bg-clip-text text-7xl font-bold text-transparent">
      404
    </p>
    <h1 class="text-foreground mt-4 text-2xl font-bold tracking-tight">Page not found</h1>
    <p class="text-muted-foreground mt-2">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8 flex gap-3">
      <Button asChild variant="gradient">
        <a href="/">Back home</a>
      </Button>
      <Button asChild variant="outline">
        <a href="/work">View work</a>
      </Button>
    </div>
  </section>
</PageLayout>

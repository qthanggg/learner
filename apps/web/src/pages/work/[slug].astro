---
import { Image } from "astro:assets"
import PageLayout from "../../layouts/PageLayout.astro"
import Reveal from "../../components/react/Reveal.tsx"
import { Badge } from "@leaner/ui/components/badge"
import { Button } from "@leaner/ui/components/button"
import { PROJECTS, type Project } from "../../data/projects"

export function getStaticPaths() {
  return PROJECTS.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

interface Props {
  project: Project
}
const { project } = Astro.props

const accentText: Record<Project["accent"], string> = {
  teal: "text-brand-teal",
  pink: "text-brand-pink",
  info: "text-info",
  success: "text-success",
}
---

<PageLayout
  title={project.name}
  description={project.summary}
  path={`/work/${project.slug}`}
>
  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
    <a href="/work" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
      ← Back to work
    </a>

    <header class="mt-6">
      <div class="text-muted-foreground flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
        <span class={accentText[project.accent]}>{project.company}</span>
        <span>·</span>
        <span>{project.period}</span>
        <span>·</span>
        <span>{project.role}</span>
      </div>
      <h1 class="text-foreground mt-3 text-4xl font-bold tracking-tight text-balance sm:text-5xl">
        {project.name}
      </h1>
      <p class="text-muted-foreground mt-3 text-lg text-pretty">{project.tagline}</p>
      <p class="text-foreground/90 mt-5 leading-relaxed">{project.summary}</p>

      {
        project.liveUrl && (
          <div class="mt-6">
            <Button asChild variant="outline">
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer">
                Visit live site ↗
              </a>
            </Button>
          </div>
        )
      }
    </header>

    {/* Banner — real screenshot for live products, branded cover otherwise. */}
    <figure class="border-border/60 mt-10 overflow-hidden rounded-2xl border">
      <Image
        src={project.cover}
        alt={`${project.name} — ${project.tagline}`}
        widths={[640, 960, 1280]}
        sizes="(min-width: 768px) 48rem, 100vw"
        class="aspect-[16/10] w-full object-cover object-top"
      />
    </figure>
    {
      project.realShot && (
        <figcaption class="text-muted-foreground mt-2 text-center text-xs">
          Live screenshot of {project.liveUrl?.replace(/^https?:\/\//, "")}
        </figcaption>
      )
    }

    {/* Metrics band */}
    <Reveal client:visible>
      <dl
        class="border-border/60 bg-card/40 mt-10 grid grid-cols-2 gap-px overflow-hidden rounded-xl border sm:grid-cols-3"
      >
        {
          project.metrics.map((m) => (
            <div class="bg-background/40 p-5">
              <dt class="text-muted-foreground text-xs">{m.label}</dt>
              <dd class="text-foreground mt-1 text-2xl font-bold">{m.value}</dd>
            </div>
          ))
        }
      </dl>
    </Reveal>

    {/* Stack */}
    <section class="mt-10">
      <h2 class="text-foreground text-sm font-semibold tracking-wide uppercase">Stack</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {project.stack.map((tech) => <Badge variant="secondary">{tech}</Badge>)}
      </div>
    </section>

    {/* Highlights */}
    <section class="mt-10">
      <h2 class="text-foreground text-sm font-semibold tracking-wide uppercase">
        What I built &amp; achieved
      </h2>
      <ul class="mt-4 space-y-4">
        {
          project.highlights.map((point, i) => (
            <Reveal client:visible delay={i * 0.05} from="up">
              <li class="border-border/60 flex gap-3 border-b pb-4 last:border-0">
                <span class={`mt-1.5 size-1.5 shrink-0 rounded-full ${accentText[project.accent]} bg-current`} />
                <span class="text-foreground/90 leading-relaxed">{point}</span>
              </li>
            </Reveal>
          ))
        }
      </ul>
    </section>

    <div class="border-border/60 mt-12 flex items-center justify-between border-t pt-8">
      <a href="/work" class="text-muted-foreground hover:text-foreground text-sm transition-colors">
        ← All work
      </a>
      <Button asChild variant="gradient">
        <a href="/contact">Work with me</a>
      </Button>
    </div>
  </article>
</PageLayout>
